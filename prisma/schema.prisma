generator client {
    provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = "postgresql://neondb_owner:npg_bj6X1CADZWoq@ep-tight-river-a8lcgzo8-pooler.eastus2.azure.neon.tech/neondb?sslmode=require"
}

model Topic {
    id        Int         @id @default(autoincrement())
    title     String      @unique
    name      String      @unique
    sub_topic Sub_Topic[]
    news      News[]
}

model Sub_Topic {
    id      Int    @id @default(autoincrement())
    title   String @unique
    name    String @unique
    topicId Int
    topic   Topic  @relation(fields: [topicId], references: [id])
    news    News[]
}
model Tag {
    id      Int    @id @default(autoincrement())
    title   String @unique
    name    String @unique
    news    News[]
}
model News {
    id        Int      @id @default(autoincrement())
    title     String
    content   String
    image     String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    topics    Topic[]
    subTopics Sub_Topic[]
    tags      Tag[]
}
