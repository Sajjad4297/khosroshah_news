model Topic {postgresql://postgres.jzthiuxaqefjjuhcjrzu:[YOUR-PASSWORD]@aws-0-eu-north-1.pooler.supabase.com:6543/postgres?pgbouncer=true
    id        Int         @id @default(autoincrement())
